{
  "service_name": "g2b-summary-api",
  "service_type": "api",
  "dockerfile": "apps/g2b_summary/infra/images/summary_api/Dockerfile",
  "build_context": "..",
  "user": "${HOST_UID:-1000}:${HOST_GID:-1000}",
  "restart": "unless-stopped",
  "env_files": [
    "infra/env/postgres.env",
    "apps/g2b_summary/infra/env/api.env"
  ],
  "ports": [
    "${G2B_SUMMARY_API_HOST_PORT:-8010}:8000"
  ],
  "depends_on_service_healthy": [
    "postgres",
    "redis",
    "qdrant"
  ],
  "healthcheck": {
    "test": ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/health/live', timeout=2).read()"],
    "interval": "10s",
    "timeout": "3s",
    "retries": 5
  }
}
