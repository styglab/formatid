{
  "app": "spec_rag.workflow",
  "description": "Spec RAG index workflow",
  "requires": {
    "workers": [
      "document-parser-worker",
      "document-chunk-worker",
      "index-dense-worker",
      "index-sparse-worker"
    ],
    "platform_services": [
      "embedding",
      "postgres",
      "redis"
    ]
  },
  "worker_env_files": {
    "document-parser-worker": [
      "apps/spec_rag/workflow/infra/env/app.env"
    ],
    "document-chunk-worker": [
      "apps/spec_rag/workflow/infra/env/app.env"
    ],
    "index-dense-worker": [
      "apps/spec_rag/workflow/infra/env/app.env"
    ],
    "index-sparse-worker": [
      "apps/spec_rag/workflow/infra/env/app.env"
    ]
  },
  "allowed_worker_env": [
    "SERVICE_APP_NAME",
    "SERVICE_APP_ENV",
    "SERVICE_REDIS_URL",
    "TASK_STATUS_TTL",
    "SPEC_RAG_INDEX_QUEUE",
    "SPEC_RAG_INDEX_MAX_ATTEMPTS",
    "S3_ENDPOINT",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_SECURE",
    "S3_BUCKET",
    "SPEC_RAG_EMBEDDING_ENDPOINT",
    "SPEC_RAG_EMBEDDING_MODEL",
    "SPEC_RAG_EMBEDDING_DIMENSIONS",
    "SPEC_RAG_VECTOR_DB_ENDPOINT",
    "SPEC_RAG_VECTOR_COLLECTION",
    "QDRANT_API_KEY",
    "QDRANT_READONLY_API_KEY",
    "SPEC_RAG_SPARSE_INDEX",
    "OPENSEARCH_ENDPOINT"
  ],
  "checkpoint_store": {
    "type": "internal_postgres"
  }
}
