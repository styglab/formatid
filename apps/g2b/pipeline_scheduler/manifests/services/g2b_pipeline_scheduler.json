{
  "service_name": "g2b-pipeline-scheduler",
  "service_type": "service",
  "dockerfile": "apps/g2b/pipeline_scheduler/infra/image/Dockerfile",
  "command": [
    "python",
    "-m",
    "apps.g2b.pipeline_scheduler.app.service.run_scheduler"
  ],
  "build_context": "../..",
  "user": "${HOST_UID:-1000}:${HOST_GID:-1000}",
  "restart": "unless-stopped",
  "env_files": [
    "deploy/compose/env/postgres.env",
    "apps/g2b/pipeline_scheduler/infra/env/pipeline_scheduler.env",
    "apps/g2b/pipeline_scheduler/infra/env/app.env"
  ],
  "depends_on_service_healthy": [
    "postgres",
    "redis"
  ]
}
