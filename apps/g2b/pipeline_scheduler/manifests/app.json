{
  "app": "g2b.pipeline_scheduler",
  "description": "G2B collection pipeline app",
  "requires": {
    "queues": [
      "ingest.api",
      "ingest.file"
    ]
  },
  "data_store": {
    "type": "postgres",
    "env": "G2B_INGEST_DATABASE_URL",
    "schema": "raw",
    "sql": "apps/g2b/pipeline_scheduler/sql/raw_schema.sql"
  },
  "checkpoint_store": {
    "type": "internal_postgres"
  },
  "dashboard": {
    "summary": "apps.g2b.pipeline_scheduler.app.dashboard.build_pipeline_dashboard_summary",
    "env_files": [
      "apps/g2b/pipeline_scheduler/infra/env/app.env"
    ]
  },
  "worker_env_files": {
    "ingest-api-worker": [
      "apps/g2b/pipeline_scheduler/infra/env/app.env"
    ],
    "ingest-file-worker": [
      "apps/g2b/pipeline_scheduler/infra/env/app.env"
    ]
  },
  "allowed_worker_env": [
    "PUBLIC_API_KEY",
    "G2B_INGEST_DATABASE_URL",
    "G2B_INGEST_SERVICE_MODE",
    "G2B_INGEST_BACKFILL_START",
    "G2B_INGEST_WINDOW_MINUTES",
    "G2B_INGEST_INCREMENTAL_LOOKBACK_MINUTES",
    "G2B_INGEST_API_TIMEOUT_SECONDS",
    "G2B_INGEST_API_NUM_OF_ROWS",
    "G2B_INGEST_MAX_FAILED_RETRIES",
    "G2B_INGEST_RETRY_FAILED_AFTER_SECONDS",
    "G2B_INGEST_S3_ENDPOINT",
    "G2B_INGEST_S3_ACCESS_KEY",
    "G2B_INGEST_S3_SECRET_KEY",
    "G2B_INGEST_S3_BUCKET",
    "G2B_INGEST_S3_SECURE"
  ]
}
