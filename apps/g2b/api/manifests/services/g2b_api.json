{
  "service_name": "g2b-api",
  "service_type": "api",
  "dockerfile": "apps/g2b/api/infra/image/Dockerfile",
  "build_context": "../..",
  "user": "${HOST_UID:-1000}:${HOST_GID:-1000}",
  "restart": "unless-stopped",
  "env_files": [
    "deploy/compose/env/postgres.env"
  ],
  "ports": [
    "${G2B_API_HOST_PORT:-8010}:8000"
  ],
  "depends_on_service_healthy": [
    "postgres",
    "redis"
  ],
  "healthcheck": {
    "test": ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/health/live', timeout=2).read()"],
    "interval": "10s",
    "timeout": "3s",
    "retries": 5
  }
}
