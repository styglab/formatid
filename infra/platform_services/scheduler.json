{
  "service_name": "scheduler",
  "dockerfile": "infra/images/scheduler/Dockerfile",
  "build_context": "..",
  "user": "${HOST_UID:-1000}:${HOST_GID:-1000}",
  "restart": "unless-stopped",
  "env_files": [
    "infra/env/postgres.env",
    "infra/env/scheduler.env"
  ],
  "depends_on_service_healthy": [
    "postgres",
    "redis"
  ]
}
