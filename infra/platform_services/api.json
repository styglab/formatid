{
  "service_name": "api",
  "dockerfile": "infra/images/api/Dockerfile",
  "build_context": "..",
  "user": "${HOST_UID:-1000}:${HOST_GID:-1000}",
  "restart": "unless-stopped",
  "env_files": [
    "infra/env/postgres.env",
    "infra/env/api.env"
  ],
  "ports": [
    "${API_HOST_PORT:-8000}:${API_CONTAINER_PORT:-8000}"
  ],
  "depends_on_service_healthy": [
    "postgres",
    "redis"
  ],
  "healthcheck": {
    "test": [
      "CMD",
      "python",
      "-c",
      "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health/live', timeout=2)"
    ],
    "interval": "5s",
    "timeout": "3s",
    "retries": 10
  }
}
