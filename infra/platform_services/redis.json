{
  "service_name": "redis",
  "image": "redis:7-alpine",
  "ports": [
    "${REDIS_HOST_PORT:-6379}:${REDIS_CONTAINER_PORT:-6379}"
  ],
  "volumes": [
    "./redis/redis.conf:/usr/local/etc/redis/redis.conf:ro"
  ],
  "healthcheck": {
    "test": [
      "CMD",
      "redis-cli",
      "ping"
    ],
    "interval": "2s",
    "timeout": "2s",
    "retries": 10
  }
}
