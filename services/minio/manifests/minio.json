{
  "service_name": "minio",
  "service_type": "object_storage",
  "image": "minio/minio:RELEASE.2025-04-22T22-12-26Z",
  "command": [
    "server",
    "/data",
    "--console-address",
    ":9001"
  ],
  "restart": "unless-stopped",
  "env_files": [
    "deploy/compose/env/minio.env"
  ],
  "ports": [
    "${MINIO_API_HOST_PORT:-9000}:9000",
    "${MINIO_CONSOLE_HOST_PORT:-9001}:9001"
  ],
  "volumes": [
    "${MINIO_DATA_DIR:-../../data/minio}:/data"
  ]
}
