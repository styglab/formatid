{
  "service_name": "prefect-postgres",
  "image": "postgres:14",
  "restart": "unless-stopped",
  "env_files": [
    "deploy/compose/env/prefect.env"
  ],
  "volumes": [
    "${PREFECT_POSTGRES_DATA_DIR:-../../data/prefect/postgres}:/var/lib/postgresql/data"
  ],
  "healthcheck": {
    "test": ["CMD-SHELL", "pg_isready -U prefect"],
    "interval": "5s",
    "timeout": "5s",
    "retries": 5
  }
}
