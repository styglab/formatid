{
  "extract.text.run": {
    "queue": "extract.text",
    "module_path": "services.extract.app.tasks.text",
    "payload_schema": "services.extract.app.tasks.schemas.TextExtractStorePayload",
    "max_retries": 3,
    "retryable": true,
    "backoff_seconds": 5,
    "timeout_seconds": 300,
    "dlq_enabled": true,
    "dlq_requeue_limit": 3
  }
}
