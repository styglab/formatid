{
  "serve.llm.generate": {
    "queue": "serve.llm",
    "module_path": "services.llm.app.tasks.llm",
    "payload_schema": "services.llm.app.tasks.schemas.LlmGenerateStorePayload",
    "max_retries": 3,
    "retryable": true,
    "backoff_seconds": 5,
    "timeout_seconds": 300,
    "dlq_enabled": true,
    "dlq_requeue_limit": 3
  }
}
