{
  "serve.llm.generate": {
    "service_name": "serve-llm-worker",
    "queue_name": "serve:llm",
    "module_path": "services.llm.tasks.llm",
    "payload_schema": "services.llm.tasks.schemas.LlmGenerateStorePayload",
    "max_retries": 3,
    "retryable": true,
    "backoff_seconds": 5,
    "timeout_seconds": 300,
    "dlq_enabled": true,
    "dlq_requeue_limit": 3
  }
}
